    "next": "^16.2.9",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "uuid": "^14.0.0",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
