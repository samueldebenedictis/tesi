# Copia questo file in .env.local e compila i valori

# ── Sviluppo locale ────────────────────────────────────────────────────────────
# Redis locale via Docker Compose: docker compose up -d redis
# Lascia vuoto per usare il fallback in-memory (nessun multiplayer persistente)
REDIS_URL=redis://localhost:6379

# Segreto per accedere a GET /api/feedback (es. curl .../api/feedback?secret=xxx)
FEEDBACK_SECRET=cambia-questo-valore

# ── Produzione (Vercel KV) ─────────────────────────────────────────────────────
# Forniti automaticamente da Vercel quando si collega un KV store.
# Non servono in sviluppo locale se REDIS_URL è impostato.
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
